generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model CaseStudy {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  subtitle  String   @default("")
  category  String
  image     String   @default("")
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
